# Configuraciones de la base de datos
# NO NECESARIAS DE MOMENTO AL USAR SQLITE:

#DATABASE_NAME=mydatabase          # Nombre de la base de datos
#DATABASE_USER=myuser              # Nombre de usuario para la base de datos
#DATABASE_PASSWORD=mypassword      # Contraseña para el usuario de la base de datos
#DATABASE_HOST=db                  # Nombre del servicio de la base de datos en docker-compose
#DATABASE_PORT=5432                # Puerto de la base de datos (por defecto es 5432 para PostgreSQL)

# Configuraciones de Django
DJANGO_SECRET_KEY=admin # Clave secreta de Django para la seguridad
DEBUG=True                         # Si la aplicación está en modo de depuración

# Otras configuraciones
ALLOWED_HOSTS=localhost,127.0.0.1 # Hosts permitidos para la aplicación
